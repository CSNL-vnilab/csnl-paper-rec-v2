# csnl-paper-rec-v2 — copy to .env (never commit). Manual/validation phase.
#
# Supabase (one Postgres data plane). The postgres pooler role bypasses RLS:
#   - csnl_research schema  : interest source, used READ-ONLY (SELECT only).
#   - csnl_paper_rec schema : recommendation ledger, READ-WRITE (this project).
# Reuse the values in ~/.claude/csnl-archive/.env.
SUPABASE_DB_HOST=
SUPABASE_DB_PORT=5432
SUPABASE_DB_NAME=postgres
SUPABASE_DB_USER=
SUPABASE_DB_PASSWORD=

# Ledger schema name (created by scripts/init_db.py; never csnl_research).
CPR_LEDGER_SCHEMA=csnl_paper_rec

# Slack bot token (xoxb-*). Bot token only, never a user token.
# Delivery is HARD-BLOCKED to dry-run until operator approval
# (--send --operator-approved + state/.APPROVED_<RUN_ID>).
SLACK_BOT_TOKEN=

# DELIBERATELY ABSENT: ANTHROPIC_API_KEY, OPENROUTER_API_KEY, OLLAMA_*.
# Rank/draft is done by the in-session Opus agent team (operator-driven),
# NOT an API key and NOT cron. (Lab LLM-key policy; rules/00_scope.md.)
