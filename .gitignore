# secrets / env
.env
.env.local
*.key
credentials.json

# personal/local Claude Code permissions (never commit; per-machine)
.claude/settings.local.json

# state / runtime (ledger is in Postgres now; runs are local artifacts)
state/runs/
state/.APPROVED_*
state/.ARCHIVE_EMBED_APPROVED
*.log

# P13 archive dry-run artifacts (regenerable from --apply pipeline)
state/archive/*.jsonl
state/archive/*.json
state/archive/_tmp/
state/archive/queues/

# P14 taxonomy IS source data — commit it (exception to the *.json line above).
!state/archive/taxonomy.json

# caches
__pycache__/
*.pyc
.DS_Store
*.anchor-vectors.json
.embed-cache/

# node (playwright/pdfjs crawl stack)
node_modules/
