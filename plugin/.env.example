# csnl-paper-archive-interview — environment template.
#
# Copy this file to ~/.csnl-paper-archive/.env (recommended — survives
# plugin reinstalls). Fill in the 5 values the operator (jy061100@gmail.com)
# shares via 1Password / Bitwarden / sealed DM.
#
# Lock it down so other users on this machine cannot read it:
#   chmod 600 ~/.csnl-paper-archive/.env
#
# Boundaries enforced regardless of which DB role you use here:
#  * plugin/scripts/_pdb.py blocks any write outside the 4 plugin-writeable
#    tables (archive_interview_sessions, archive_profile_verifications,
#    archive_responses, archive_meta_reviews) and refuses multi-statement
#    SQL or TRUNCATE/DROP/ALTER. The plugin will not corrupt the lab DB
#    even though the role technically has admin rights.

SUPABASE_DB_HOST=
SUPABASE_DB_PORT=5432
SUPABASE_DB_NAME=postgres
SUPABASE_DB_USER=
SUPABASE_DB_PASSWORD=

# Schema name — leave as default unless the operator tells you otherwise.
CPR_LEDGER_SCHEMA=csnl_paper_rec
