# csnl-paper-archive-interview — environment template.
# Copy to `<plugin-dir>/.env` or `~/.csnl-paper-archive/.env`.
# Talk to jy061100@gmail.com (operator) for the actual values.

SUPABASE_DB_HOST=
SUPABASE_DB_PORT=5432
SUPABASE_DB_NAME=postgres
SUPABASE_DB_USER=
SUPABASE_DB_PASSWORD=

# Schema name. Defaults to csnl_paper_rec if unset.
CPR_LEDGER_SCHEMA=csnl_paper_rec

# Embedding backend used for the "tell me more" option 4 deep-dive. If you
# don't intend to use option 4, leave this as 'none'. Otherwise 'local'
# requires sentence-transformers + bge-m3 (1024-dim, multilingual). API
# backends require explicit operator approval.
CSNL_EMBED_BACKEND=none
CSNL_EMBED_MODEL=BAAI/bge-m3
