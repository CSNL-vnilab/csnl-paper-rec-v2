# csnl-paper-archive-interview — environment template.
#
# Copy this file to ONE of:
#   ~/.csnl-paper-archive/.env             ← recommended (survives reinstalls)
#   <plugin-install-dir>/.env              ← alternate; wins over the home file
#
# Get the values from the lab operator (jy061100@gmail.com). The operator
# provisions a scoped Postgres role via state/provision/csnl_archive_user.sql
# — DO NOT use the lab's `postgres` pooler role here.

SUPABASE_DB_HOST=          # e.g. aws-1-ap-southeast-1.pooler.supabase.com
SUPABASE_DB_PORT=5432
SUPABASE_DB_NAME=postgres
SUPABASE_DB_USER=csnl_archive_user
SUPABASE_DB_PASSWORD=      # provided by operator (1Password / sealed DM)

# Schema name. Defaults to csnl_paper_rec if unset.
CPR_LEDGER_SCHEMA=csnl_paper_rec

# Lock down the file so other users on this machine cannot read it:
#   chmod 600 ~/.csnl-paper-archive/.env

# Optional — embedding backend for option-4 "tell me more" deep-dive.
# Default is 'none' (the explainer uses the paper's stored abstract).
# 'local' requires sentence-transformers + the bge-m3 weights locally.
# API backends ('voyage', 'jina', 'openai') require explicit operator
# approval — do not set without coordination.
CSNL_EMBED_BACKEND=none
CSNL_EMBED_MODEL=BAAI/bge-m3
